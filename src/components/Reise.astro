---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const phases = [
  {
    num: '01',
    label: 'Phase 1',
    title: 'Entlastung',
    subtitle: 'Routinen automatisieren, Köpfe freiräumen.',
    text: 'In der ersten Phase übernimmt 42°OS die repetitiven, zeitraubenden Aufgaben: Dokumentenverarbeitung, Dateneingaben, Routinekommunikation. Ihr Team kann sich wieder auf das konzentrieren, wofür es eingestellt wurde.',
    image: 'phase-entlastung.webp',
    imageAlt: 'Phase Entlastung – Mitarbeiter befreit von Routineaufgaben, fokussiert auf wertvolle Arbeit',
    outcome: 'Bis zu 40% Zeitersparnis bei Routineaufgaben',
    color: 'phase--azure',
  },
  {
    num: '02',
    label: 'Phase 2',
    title: 'Ermächtigung',
    subtitle: 'Prozesse gestalten, ohne Programmierer.',
    text: 'In der zweiten Phase werden Ihre Fachabteilungen zu Gestaltern. Mit dem No-Code Workflow Designer und 50+ vortrainierten KI-Agenten optimieren sie ihre eigenen Prozesse – ohne IT-Ticket, ohne Wartezeit.',
    image: 'phase-ermaechtigung.webp',
    imageAlt: 'Phase Ermächtigung – Mitarbeiter gestalten eigenständig Automatisierungsprozesse mit 42°OS',
    outcome: 'Fachabteilungen werden eigenständig',
    color: 'phase--mint',
  },
  {
    num: '03',
    label: 'Phase 3',
    title: 'Transformation',
    subtitle: 'Strategisch wachsen, souverän bleiben.',
    text: 'In der dritten Phase entfaltet 42°OS sein volles Potenzial: Unternehmensweite Automatisierung, datengetriebene Entscheidungen, skalierbare KI-Kapazitäten – und das alles auf Ihrer eigenen Infrastruktur, unter Ihrer vollständigen Kontrolle.',
    image: 'phase-transformation.webp',
    imageAlt: 'Phase Transformation – Unternehmen wächst digital-souverän mit KI-gestützten Prozessen',
    outcome: 'Strategische Wettbewerbsvorteile durch KI',
    color: 'phase--dark',
  },
];
---

<section class="reise">
  <div class="container">
    <div class="reise-header">
      <span class="section-label">Die Reise</span>
      <h2 class="reise-title">Drei Phasen.<br /><span class="highlight">Ein souveräner Weg.</span></h2>
      <p class="reise-intro">
        Jedes Unternehmen geht seinen eigenen Weg. 42°OS begleitet Sie – von den ersten automatisierten Routinen bis zur unternehmensweiten KI-Transformation. In Ihrem Tempo, auf Ihrer Infrastruktur.
      </p>
    </div>

    <div class="phases-grid">
      {phases.map((phase) => (
        <div class={`phase-card ${phase.color}`}>
          <div class="phase-image-wrapper">
            <img
              src={`${base}/images/${phase.image}`}
              alt={phase.imageAlt}
              class="phase-img"
              loading="lazy"
              width="420"
              height="300"
            />
          </div>
          <div class="phase-content">
            <div class="phase-meta">
              <span class="phase-num">{phase.num}</span>
              <span class="phase-label-tag">{phase.label}</span>
            </div>
            <h3 class="phase-title">{phase.title}</h3>
            <p class="phase-subtitle">{phase.subtitle}</p>
            <p class="phase-text">{phase.text}</p>
            <div class="phase-outcome">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8l4 4 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{phase.outcome}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Phase connector arrow (desktop) -->
    <div class="phase-connector" aria-hidden="true">
      <span class="connector-step">Entlastung</span>
      <svg width="40" height="16" viewBox="0 0 40 16" fill="none"><path d="M0 8h36M28 2l8 6-8 6" stroke="var(--color-accent-bright)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="connector-step">Ermächtigung</span>
      <svg width="40" height="16" viewBox="0 0 40 16" fill="none"><path d="M0 8h36M28 2l8 6-8 6" stroke="var(--color-accent-bright)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="connector-step">Transformation</span>
    </div>
  </div>
</section>

<style>
  .reise {
    padding: var(--section-padding);
    background: #fff;
  }

  .reise-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
  }

  .reise-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .reise-title .highlight {
    color: var(--color-accent);
  }

  .reise-intro {
    font-size: 16px;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  /* Phase cards */
  .phases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .phase-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  .phase-image-wrapper {
    aspect-ratio: 7 / 5;
    overflow: hidden;
    background: linear-gradient(135deg, #0F2B46, #1a3d58);
  }

  .phase-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .phase-card:hover .phase-img {
    transform: scale(1.03);
  }

  .phase-content {
    padding: 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .phase--azure .phase-content { background: var(--color-bg-azure); }
  .phase--mint .phase-content  { background: var(--color-bg-mint); }
  .phase--dark .phase-content  { background: #0F2B46; }
  .phase--dark .phase-title,
  .phase--dark .phase-subtitle,
  .phase--dark .phase-text,
  .phase--dark .phase-label-tag { color: #fff; }
  .phase--dark .phase-num { color: var(--color-accent-bright); }
  .phase--dark .phase-outcome { color: var(--color-accent-bright); background: rgba(102,228,169,0.15); }

  .phase-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .phase-num {
    font-size: 28px;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .phase-label-tag {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  .phase-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 6px;
  }

  .phase-subtitle {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 12px;
    font-style: italic;
  }

  .phase-text {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .phase-outcome {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(15, 43, 70, 0.06);
    padding: 8px 14px;
    border-radius: 8px;
    margin-top: auto;
  }

  .phase-outcome svg {
    flex-shrink: 0;
    color: var(--color-accent-bright);
  }

  /* Connector */
  .phase-connector {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .connector-step {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .phases-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
    .phase-connector { display: none; }
  }
</style>
