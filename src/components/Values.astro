---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const values = [
  { num: '01', title: 'Souveränität', text: 'Ihre Daten, Ihre Infrastruktur, Ihre Entscheidungen. Wir liefern Technologie, die Ihnen gehört – nicht eine Dienstleistung, die Sie mieten.' },
  { num: '02', title: 'Qualität', text: 'Entwickelt in Ostwestfalen, mit dem Anspruch des deutschen Ingenieurwesens. Keine Beta-Features in der Produktion. Kein Kompromiss bei Sicherheit.' },
  { num: '03', title: 'Partnerschaft', text: 'Wir sind kein SaaS-Anbieter, der Tickets bearbeitet. Wir sind Ihr technologischer Partner – langfristig, auf Augenhöhe, erreichbar.' },
  { num: '04', title: 'Nachhaltigkeit', text: 'On-Premises bedeutet geringerer CO₂-Fußabdruck als Hyperscaler. Technologie, die ökonomisch und ökologisch Sinn ergibt.' },
  { num: '05', title: 'Innovation', text: 'Vorreiter der europäischen KI-Souveränität. Wir setzen keine Trends – wir antizipieren, was Mittelständler in drei Jahren brauchen werden.' },
];
---

<section class="values">
  <div class="container values-grid">
    <div class="values-left">
      <h2 class="values-title">Werte, die wir<br />wirklich leben.</h2>
      <p class="values-sub">Nicht nur Technologie – eine Haltung. Was uns antreibt und wie wir mit unseren Kunden arbeiten.</p>
      <a href="https://heartofgold.42-grad.com/apps/appointments/pub/Yy9ZvN4aA3A7v0qN/form" class="btn-accent values-btn" target="_blank" rel="noopener noreferrer">Jetzt Kontakt aufnehmen</a>
    </div>

    <div class="values-right">
      {values.map(value => (
        <div class="value-item">
          <span class="value-num">{value.num}.</span>
          <div>
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .values {
    padding: var(--section-padding);
    background: var(--color-bg-azure);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }

  .values-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .values-sub {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .value-item {
    display: flex;
    gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(107, 164, 255, 0.3);
  }

  .value-item:first-child { padding-top: 0; }

  .value-num {
    font-size: 16px;
    color: var(--color-azure);
    font-weight: 700;
    min-width: 30px;
  }

  .value-item h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 8px;
  }

  .value-item p {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .values-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
