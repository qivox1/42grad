---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  image?: string;   // e.g. "kv-plattform.webp" — relative to /images/
  breadcrumbs?: BreadcrumbItem[];
}

const { title, subtitle, label, image, breadcrumbs } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imageSrc = image ? `${base}/images/${image}` : null;
---

<section class={`page-hero${imageSrc ? ' page-hero--img' : ''}`}>
  {imageSrc && (
    <div class="page-hero-bg">
      <img src={imageSrc} alt="" class="page-hero-img" aria-hidden="true" loading="eager" fetchpriority="high" />
      <div class="page-hero-overlay"></div>
    </div>
  )}
  <div class="container page-hero-content">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="page-hero-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href={base + '/'}>Home</a></li>
          {breadcrumbs.map((item, i) => (
            <li>
              <span class="sep">/</span>
              {item.href && i < breadcrumbs.length - 1
                ? <a href={item.href}>{item.label}</a>
                : <span class="current">{item.label}</span>
              }
            </li>
          ))}
        </ol>
      </nav>
    )}
    {label && <span class="section-label">{label}</span>}
    <h1 class="page-hero-title" set:html={title} />
    {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .page-hero {
    padding: 100px 0 70px;
    background: linear-gradient(180deg, #f0f4f8 0%, #fff 100%);
    position: relative;
    overflow: hidden;
  }

  /* ── With background image ── */
  .page-hero--img {
    background: none;
    min-height: 340px;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Left-heavy gradient: fully opaque → fades out to the right */
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(255, 255, 255, 0.97) 0%,
      rgba(255, 255, 255, 0.93) 35%,
      rgba(255, 255, 255, 0.75) 55%,
      rgba(255, 255, 255, 0.35) 78%,
      rgba(255, 255, 255, 0.10) 100%
    );
  }

  /* ── Content ── */
  .page-hero-content {
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  /* ── Inline Breadcrumb ── */
  .page-hero-breadcrumb {
    margin-bottom: 16px;
  }

  .page-hero-breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .page-hero-breadcrumb a {
    color: var(--color-accent);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .page-hero-breadcrumb a:hover { opacity: 0.7; }

  .page-hero-breadcrumb .sep {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  .page-hero-breadcrumb .current {
    color: var(--color-text-muted);
    font-size: 13px;
  }

  .page-hero-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .page-hero-title :global(.highlight) {
    color: var(--color-accent);
  }

  .page-hero-subtitle {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .page-hero--img {
      min-height: 280px;
    }
    /* On mobile cover fully so text stays readable */
    .page-hero-overlay {
      background: rgba(255, 255, 255, 0.92);
    }
  }
</style>
