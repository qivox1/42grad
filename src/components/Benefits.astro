---
const benefits = [
  {
    title: 'Autonome Prozesse',
    text: 'Weitgehend autonome Geschäftsprozesse mit klar definierten Kontrollpunkten.',
  },
  {
    title: 'Datensouveränität',
    text: 'Vollständige Datensouveränität im eigenen Haus – Ihre Daten verlassen nie Ihre Infrastruktur.',
  },
  {
    title: 'Planbare Kosten',
    text: 'Eine skalierbare und planbare Kostenstruktur – unabhängig davon, wie stark Sie wachsen.',
  },
];
---

<section class="benefits">
  <div class="container">
    <h2 class="benefits-heading"><span class="highlight">Was 42°OS</span> für Sie bedeutet.</h2>

    <div class="benefits-grid">
      {benefits.map(benefit => (
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#66E4A9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3>{benefit.title}</h3>
          <p>{benefit.text}</p>
        </div>
      ))}
    </div>

    <div class="benefit-images">
      <div class="benefit-image-card benefit-image-quote">
        <img src="https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=500&h=400&fit=crop" alt="Modern office" loading="lazy" />
        <div class="image-overlay">
          <p>42°OS: Das Beste aus beiden Welten – Kontrolle und Innovation vereint.</p>
        </div>
      </div>
      <div class="benefit-image-card">
        <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=800&h=400&fit=crop" alt="Technology workspace" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .benefits { padding: var(--section-padding); }

  .benefits-heading {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    margin-bottom: 50px;
  }

  .benefits-heading .highlight { color: var(--color-accent); }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 48px;
  }

  .benefit-card { padding: 32px; }

  .benefit-icon {
    width: 48px;
    height: 48px;
    background: rgba(102, 228, 169, 0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .benefit-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-dark);
  }

  .benefit-card p {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .benefit-images {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 20px;
  }

  .benefit-image-card {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    min-height: 350px;
  }

  .benefit-image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px;
    background: linear-gradient(transparent, rgba(15, 43, 70, 0.85));
  }

  .image-overlay p {
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .benefits-grid { grid-template-columns: 1fr; }
    .benefit-images { grid-template-columns: 1fr; }
  }
</style>
