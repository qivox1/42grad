---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const teamMembers = [
  { name: 'Jonas Fröhleke', role: 'CEO', desc: 'MBA & Eng. Wirtschaftsingenieurwesen, >12 Jahre industrielle Automatisierung', img: `${base}/images/jonas.webp` },
  { name: 'Johann-Georg Vogelhuber', role: 'CTO', desc: 'Dipl.-Mathematiker, >20 Jahre Softwareentwicklung & KI-Systeme', img: `${base}/images/georg.webp` },
];
---

<section id="team" class="team">
  <div class="container">
    <h2 class="team-heading"><span class="highlight">Die 42grad</span> GmbH.</h2>
    <p class="team-intro">
      Gegründet Q4.2024 in Ostwestfalen – mit dem Ziel, den deutschen Mittelstand souverän in die KI-Zukunft zu führen.
    </p>

    <div class="team-grid">
      {teamMembers.map(member => (
        <div class="team-card">
          <div class="team-photo">
            <img src={member.img} alt={member.name} loading="lazy" />
          </div>
          <h3>{member.name}</h3>
          <span class="team-role">{member.role}</span>
          <p>{member.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team { padding: var(--section-padding); }

  .team-heading {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .team-heading .highlight { color: var(--color-accent); }

  .team-intro {
    font-size: 16px;
    color: var(--color-text-light);
    max-width: 600px;
    line-height: 1.6;
    margin-bottom: 60px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
    max-width: 800px;
  }

  .team-card { text-align: left; }

  .team-photo {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 20px;
    aspect-ratio: 1;
    background: #f0f4f8;
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.3s;
  }

  .team-card:hover .team-photo img {
    filter: brightness(1.05);
  }

  .team-card h3 {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 4px;
  }

  .team-role {
    display: inline-block;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .team-card p {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .team-grid { grid-template-columns: 1fr; max-width: 400px; }
  }
</style>
