---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <!-- Background image (single, static) -->
  <div class="hero-bg-img">
    <img
      src={`${base}/images/header_hero_01.webp`}
      alt=""
      class="hero-img"
      aria-hidden="true"
      width="1920"
      height="816"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <!-- Decorative crosses -->
  <div class="hero-crosses">
    <span class="cross" style="top: 80px; left: 12%"></span>
    <span class="cross" style="top: 200px; left: 6%"></span>
    <span class="cross" style="top: 120px; right: 14%"></span>
    <span class="cross" style="top: 280px; right: 8%"></span>
    <span class="cross" style="bottom: 100px; left: 20%"></span>
    <span class="cross" style="bottom: 60px; right: 20%"></span>
  </div>

  <div class="container hero-content">
    <span class="section-label">Technologie aus Ostwestfalen</span>
    <h1 class="hero-title">
      Volle Kontrolle.<br /><span class="highlight-mint">Freiheit zur Innovation.</span>
    </h1>
    <p class="hero-subtitle">
      42°OS ist die On-Premises-Plattform für autonome Geschäftsprozesse<br />
      für den deutschen Mittelstand.
    </p>
    <div class="hero-buttons">
      <a href="https://heartofgold.42-grad.com/apps/appointments/pub/Yy9ZvN4aA3A7v0qN/form" class="btn-accent" target="_blank" rel="noopener noreferrer">Demo vereinbaren</a>
      <a href="#solutions" class="btn-outline">Mehr erfahren</a>
    </div>
  </div>

  <div class="container hero-clients">
    <p class="clients-label">Internationale Unternehmen vertrauen uns</p>
    <div class="clients-logos">
      <span class="client-logo">heroal</span>
      <span class="client-logo">K60</span>
      <span class="client-logo">REME</span>
      <span class="client-logo">DarKo</span>
      <span class="client-logo">BIO-CIRCLE</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 100px 0 60px;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Background image ── */
  .hero-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(10, 22, 38, 0.82) 0%,
      rgba(15, 43, 70, 0.72) 55%,
      rgba(15, 43, 70, 0.45) 100%
    );
    z-index: 1;
  }

  /* ── Decorative ── */
  .hero-crosses {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  /* ── Content ── */
  .hero-content {
    text-align: center;
    position: relative;
    z-index: 3;
  }

  /* Override global section-label for dark hero */
  .hero-content .section-label {
    color: var(--color-accent-bright);
    opacity: 1;
    background: rgba(102, 228, 169, 0.12);
    border: 1px solid rgba(102, 228, 169, 0.3);
    border-radius: 20px;
    padding: 4px 14px;
    display: inline-block;
    margin-bottom: 20px;
  }

  /* btn-outline on dark background */
  .hero-content .btn-outline {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero-content .btn-outline:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }

  .hero-title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  .highlight-mint {
    color: var(--color-accent-bright);
  }

  .hero-subtitle {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 36px;
    line-height: 1.7;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.2);
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
  }

  /* ── Clients ── */
  .hero-clients {
    margin-top: 80px;
    text-align: center;
    position: relative;
    z-index: 3;
  }

  .clients-label {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .clients-logos {
    display: flex;
    gap: 48px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .client-logo {
    font-size: 18px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 0 40px;
      min-height: 70vh;
    }
    .hero-subtitle br {
      display: none;
    }
    .hero-buttons {
      flex-direction: column;
    }
    .clients-logos {
      gap: 24px;
    }
  }
</style>
