---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const footerColumns = [
  {
    title: 'Plattform',
    links: [
      { label: 'Architektur', href: base + '/plattform/#architektur' },
      { label: 'Sicherheit', href: base + '/plattform/#sicherheit' },
      { label: 'Compliance', href: base + '/plattform/#compliance' },
      { label: 'Konnektoren', href: base + '/plattform/#konnektoren' },
    ],
  },
  {
    title: 'Funktionen',
    links: [
      { label: 'No-Code Designer', href: base + '/funktionen/#no-code-designer' },
      { label: 'Agentic AI', href: base + '/funktionen/#agentic-ai' },
      { label: '50+ Agenten', href: base + '/funktionen/#agenten' },
      { label: 'App Builder', href: base + '/funktionen/#app-builder' },
    ],
  },
  {
    title: 'Unternehmen',
    links: [
      { label: 'Über uns', href: base + '/ueber-uns/' },
      { label: 'Team', href: base + '/ueber-uns/team/' },
      { label: 'Karriere', href: base + '/ueber-uns/karriere/' },
      { label: 'Ressourcen', href: base + '/ressourcen/' },
    ],
  },
];
---

<footer id="contact" class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href={base + '/'} class="footer-logo">
        <img src={`${base}/images/logo-light.webp`} alt="42 Grad" class="footer-logo-img" />
      </a>

      <h2 class="footer-heading">
        <span class="highlight">42°OS</span> On-Premises Plattform für autonome Geschäftsprozesse
      </h2>

      <p class="footer-tagline">Technologie aus Ostwestfalen</p>
    </div>

    <div class="footer-right">
      <div class="footer-columns">
        {footerColumns.map(col => (
          <div class="footer-col">
            <h3 class="footer-col-title">{col.title}</h3>
            <nav class="footer-col-nav">
              {col.links.map(link => (
                <a href={link.href} class="footer-link">{link.label}</a>
              ))}
            </nav>
          </div>
        ))}
      </div>

      <p class="footer-desc">
        Kontaktieren Sie uns für eine unverbindliche Demo und erfahren Sie, wie 42°OS Ihre Geschäftsprozesse automatisieren kann – sicher, souverän und skalierbar.
      </p>

      <a href="https://heartofgold.42-grad.com/apps/appointments/pub/Yy9ZvN4aA3A7v0qN/form" class="btn-footer" target="_blank" rel="noopener noreferrer">Demo vereinbaren</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; 2024-2026 42grad GmbH. Alle Rechte vorbehalten.</span>
    <div class="footer-legal">
      <a href={base + '/impressum/'} class="footer-legal-link">Impressum</a>
      <a href={base + '/datenschutz/'} class="footer-legal-link">Datenschutzerklärung</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0F2B46;
    color: #fff;
    padding: 80px 0 32px;
    position: relative;
    overflow: hidden;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    border: 1px solid rgba(102, 228, 169, 0.1);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 60px;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 32px;
  }

  .footer-logo-img {
    width: 150px;
    height: auto;
  }

  .footer-heading {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 16px;
    color: #fff;
  }

  .footer-heading .highlight { color: var(--color-accent-bright); }

  .footer-tagline {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 32px;
  }

  .footer-col-title {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-col-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    transition: color 0.2s;
  }

  .footer-link:hover { color: var(--color-accent); }

  .footer-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 500px;
  }

  .btn-footer {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 36px;
    background: var(--color-accent-bright);
    color: var(--color-dark);
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    transition: all 0.3s;
  }

  .btn-footer:hover { background: #52d696; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .footer-legal {
    display: flex;
    gap: 24px;
  }

  .footer-legal-link {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
    font-size: 13px;
  }

  .footer-legal-link:hover { color: var(--color-accent); }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 40px; }
    .footer-bottom { flex-direction: column; gap: 12px; }
  }
</style>
