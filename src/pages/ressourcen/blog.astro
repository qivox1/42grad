---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Alle freigegebenen Blog-Artikel, sortiert nach Datum (neueste zuerst)
const allPosts = await getCollection('blog', ({ data }) => {
  return data.status === 'Freigegeben';
});

const posts = allPosts.sort((a, b) =>
  new Date(b.data.date_published).getTime() - new Date(a.data.date_published).getTime()
);

// Datum für Anzeige formatieren (de-DE)
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(date));
}
---

<Layout title="Blog – KI, Automatisierung und Mittelstand | 42grad GmbH"
  description="Blog der 42grad GmbH: Fachartikel zu KI im Mittelstand, On-Premises-Automatisierung, DSGVO-konformer KI und digitaler Transformation.">
  <Header />
  <main class="page">
    <PageHero
      breadcrumbs={[{label:'Ressourcen', href: base + '/ressourcen/'}, {label:'Blog'}]}
      title="<span class='highlight'>Blog</span>"
      subtitle="Insights, Updates und Wissenswertes rund um KI im Mittelstand"
      image="kv-ressourcen.webp"
    />
    <div class="container">

      <section class="intro-section">
        <p>
          Lesen Sie tiefe Artikel über KI-Technologie, Geschäftsprozess-Automatisierung und digitale Transformation im Mittelstand. Experten-Insights und praktische Tipps von unserem Team.
        </p>
      </section>

      <section class="blog-section">
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card blog-card--live">
              <a href={`${base}/ressourcen/blog/${post.slug}/`} class="blog-card-link" aria-label={`Weiterlesen: ${post.data.title}`}>
                <div class="blog-image-wrapper">
                  {post.data.featured_image ? (
                    <img
                      src={`${base}/images/${post.data.featured_image}`}
                      alt={post.data.featured_image_alt || post.data.title}
                      class="blog-featured-img"
                      loading="lazy"
                    />
                  ) : (
                    <div class="blog-image-placeholder">
                      <div class="placeholder-icon">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M4 4h16v16H4V4z" stroke="currentColor" stroke-width="2"/>
                          <path d="M6 8h12M6 12h12M6 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                    </div>
                  )}
                  {post.data.category && (
                    <span class="blog-category">{post.data.category}</span>
                  )}
                </div>
                <div class="blog-content">
                  <div class="blog-meta">
                    <span class="blog-date">{formatDate(post.data.date_published)}</span>
                    {post.data.estimated_read_time && (
                      <span class="blog-read-time">· {post.data.estimated_read_time}</span>
                    )}
                  </div>
                  <h2 class="blog-title">{post.data.title}</h2>
                  <p class="blog-excerpt">{post.data.excerpt}</p>
                  {post.data.author_name && (
                    <div class="blog-author">
                      <span class="author-name">{post.data.author_name}</span>
                    </div>
                  )}
                  <span class="read-more">Weiterlesen →</span>
                </div>
              </a>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="empty-state">
            <p>Noch keine Artikel veröffentlicht. Bald mehr.</p>
          </div>
        )}
      </section>

      <section class="newsletter-section">
        <h2>Newsletter</h2>
        <div class="newsletter-content">
          <p>
            Möchten Sie über neue Artikel, Produkt-Updates und KI-Insights informiert bleiben? Abonnieren Sie unseren Newsletter.
          </p>
          <form class="newsletter-form">
            <label for="newsletter-email" class="visually-hidden">E-Mail-Adresse</label>
            <input type="email" id="newsletter-email" name="email" placeholder="Ihre E-Mail-Adresse" required />
            <button type="submit" class="btn-accent">Abonnieren</button>
          </form>
          <p class="newsletter-note">
            Wir senden nur relevante Updates. Keine Spam, kein Unsinn. Abmelden jederzeit möglich.
          </p>
        </div>
      </section>

      <section class="coming-soon-section">
        <h2>Weitere Artikel folgen in Kürze</h2>
        <div class="coming-soon-content">
          <p>
            Unser Blog wächst regelmäßig. Neue Artikel werden veröffentlicht, um Sie über die neuesten Entwicklungen in KI, Mittelstand und digitaler Transformation auf dem Laufenden zu halten.
          </p>
          <div class="planned-topics">
            <h3>In Planung:</h3>
            <ul>
              <li>KI-Agenten in der Rechnungsverarbeitung – echte ROI-Berechnungen</li>
              <li>Skalierbare On-Premises-Infrastruktur – Planung und Implementierung</li>
              <li>Integration mit bestehenden ERP-Systemen – Best Practices</li>
              <li>Compliance und Audit bei KI-Automatisierung – Was Revisoren prüfen</li>
              <li>Die Zukunft von mittelständischen Unternehmen in der KI-Ära</li>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </main>
  <CTA />
  <Footer />
</Layout>

<style>

  .intro-section {
    margin: 60px 0 80px;
    max-width: 700px;
  }

  .intro-section p {
    font-size: 16px;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .blog-section {
    margin: 80px 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 32px;
  }

  /* Live Article Card */
  .blog-card--live {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .blog-card--live:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15, 43, 70, 0.08);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    height: 100%;
  }

  .blog-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .blog-featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0F2B46 0%, #1a3d52 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon svg {
    width: 48px;
    height: 48px;
    color: #fff;
  }

  .blog-category {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: var(--color-accent-bright);
    color: var(--color-dark);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .blog-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
  }

  .blog-date {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .blog-read-time {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .blog-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-dark);
    line-height: 1.4;
    margin-bottom: 12px;
  }

  .blog-excerpt {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    flex-grow: 1;
    margin-bottom: 16px;
  }

  .blog-author {
    margin-bottom: 16px;
  }

  .author-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
  }

  .read-more {
    color: var(--color-accent);
    font-size: 14px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .blog-card--live:hover .read-more {
    opacity: 0.8;
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--color-text-muted);
    font-size: 16px;
  }

  .newsletter-section {
    margin: 100px 0;
    background: linear-gradient(135deg, #f0f4f8 0%, #e8f0f8 100%);
    border-radius: 20px;
    padding: 60px 40px;
  }

  .newsletter-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 32px;
  }

  .newsletter-content {
    max-width: 600px;
  }

  .newsletter-content p {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .newsletter-form {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .newsletter-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
  }

  .newsletter-form input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-form button {
    padding: 12px 28px;
    background: var(--color-accent-bright);
    color: var(--color-dark);
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s;
  }

  .newsletter-form button:hover {
    background: #52d696;
  }

  .newsletter-note {
    font-size: 12px;
    color: var(--color-text-muted) !important;
    margin: 0 !important;
  }

  .coming-soon-section {
    margin: 100px 0 0;
    background: #0F2B46;
    border-radius: 20px;
    padding: 60px 40px;
    color: #fff;
  }

  .coming-soon-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 32px;
  }

  .coming-soon-content {
    max-width: 700px;
  }

  .coming-soon-content p {
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .planned-topics h3 {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
  }

  .planned-topics ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .planned-topics li {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    margin-bottom: 12px;
    padding-left: 24px;
    position: relative;
  }

  .planned-topics li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent-bright);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .newsletter-section,
    .coming-soon-section {
      padding: 40px 20px;
    }

    .newsletter-section h2,
    .coming-soon-section h2 {
      font-size: 28px;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
