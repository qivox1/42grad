---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Blog - 42°OS">
  <Header />
  <main class="page">
    <div class="container">
      <Breadcrumb items={[{label:'Ressourcen', href: base + '/ressourcen'}, {label:'Blog'}]} />

      <PageHero
        title="<span class='highlight'>Blog</span>"
        subtitle="Insights, Updates und Wissenswertes rund um KI im Mittelstand"
      />

      <section class="intro-section">
        <p>
          Lesen Sie tiefe Artikel über KI-Technologie, Geschäftsprozess-Automatisierung und digitale Transformation im Mittelstand. Experten-Insights und praktische Tipps von unserem Team.
        </p>
      </section>

      <section class="blog-section">
        <div class="blog-grid">
          <article class="blog-card">
            <div class="blog-image-placeholder">
              <div class="placeholder-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 4h16v16H4V4z" stroke="currentColor" stroke-width="2"/>
                  <path d="M6 8h12M6 12h12M6 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
            <div class="blog-content">
              <span class="blog-date">März 2026</span>
              <h3>Warum On-Premises KI die Zukunft des Mittelstands ist</h3>
              <p>
                Cloud ist nicht immer die Lösung. Für sensible Daten und strategische Prozesse ist On-Premises KI der richtige Weg. Wir erklären, warum Datensouveränität wichtiger denn je ist.
              </p>
              <a href="#" class="read-more">Weiterlesen →</a>
            </div>
          </article>

          <article class="blog-card">
            <div class="blog-image-placeholder">
              <div class="placeholder-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 4h16v16H4V4z" stroke="currentColor" stroke-width="2"/>
                  <path d="M6 8h12M6 12h12M6 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
            <div class="blog-content">
              <span class="blog-date">Februar 2026</span>
              <h3>DSGVO und KI: Was Geschäftsführer wissen müssen</h3>
              <p>
                KI und Datenschutz – sind das Gegensätze? Nein. Wir zeigen, wie KI-Systeme DSGVO-konform funktionieren und was Geschäftsführer beachten müssen.
              </p>
              <a href="#" class="read-more">Weiterlesen →</a>
            </div>
          </article>

          <article class="blog-card">
            <div class="blog-image-placeholder">
              <div class="placeholder-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 4h16v16H4V4z" stroke="currentColor" stroke-width="2"/>
                  <path d="M6 8h12M6 12h12M6 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
            <div class="blog-content">
              <span class="blog-date">Januar 2026</span>
              <h3>No-Code Automatisierung: Der Schlüssel zur digitalen Transformation</h3>
              <p>
                Sie brauchen keine Programmierer, um Ihre Prozesse zu automatisieren. No-Code-Plattformen demokratisieren KI und machen sie zugänglich für jeden.
              </p>
              <a href="#" class="read-more">Weiterlesen →</a>
            </div>
          </article>

          <article class="blog-card">
            <div class="blog-image-placeholder">
              <div class="placeholder-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 4h16v16H4V4z" stroke="currentColor" stroke-width="2"/>
                  <path d="M6 8h12M6 12h12M6 16h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
            <div class="blog-content">
              <span class="blog-date">Dezember 2025</span>
              <h3>42°OS im Praxistest: Erste Pilotanwender berichten</h3>
              <p>
                Wie reagieren echte Kunden auf 42°OS? Wir sprechen mit unseren Pilotanwendern über ihre Erfahrungen, Lernpunkte und ersten Erfolge.
              </p>
              <a href="#" class="read-more">Weiterlesen →</a>
            </div>
          </article>
        </div>
      </section>

      <section class="newsletter-section">
        <h2>Newsletter</h2>
        <div class="newsletter-content">
          <p>
            Möchten Sie über neue Artikel, Produkt-Updates und KI-Insights informiert bleiben? Abonnieren Sie unseren Newsletter.
          </p>
          <form class="newsletter-form">
            <input type="email" placeholder="Ihre E-Mail-Adresse" required />
            <button type="submit" class="btn-accent">Abonnieren</button>
          </form>
          <p class="newsletter-note">
            Wir senden nur relevante Updates. Keine Spam, kein Unsinn. Abmelden jederzeit möglich.
          </p>
        </div>
      </section>

      <section class="coming-soon-section">
        <h2>Weitere Artikel folgen in Kürze</h2>
        <div class="coming-soon-content">
          <p>
            Unser Blog wächst regelmäßig. Neue Artikel werden veröffentlicht, um Sie über die neuesten Entwicklungen in KI, Mittelstand und digitaler Transformation auf dem Laufenden zu halten.
          </p>
          <div class="planned-topics">
            <h3>In Planung:</h3>
            <ul>
              <li>KI-Agenten in der Rechnungsverarbeitung – echte ROI-Berechnungen</li>
              <li>Skalierbare On-Premises-Infrastruktur – Planung und Implementierung</li>
              <li>Integration mit bestehenden ERP-Systemen – Best Practices</li>
              <li>Compliance und Audit bei KI-Automatisierung – Was Revisoren prüfen</li>
              <li>Die Zukunft von mittelständischen Unternehmen in der KI-Ära</li>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </main>
  <CTA />
  <Footer />
</Layout>

<style>
  .page {
    padding-top: 20px;
  }

  .intro-section {
    margin: 60px 0 80px;
    max-width: 700px;
  }

  .intro-section p {
    font-size: 16px;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .blog-section {
    margin: 80px 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 32px;
  }

  .blog-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15, 43, 70, 0.08);
  }

  .blog-image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #0F2B46 0%, #1a3d52 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .blog-image-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(102, 228, 169, 0.1);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .blog-card:hover .blog-image-placeholder::before {
    opacity: 1;
  }

  .placeholder-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .placeholder-icon svg {
    width: 48px;
    height: 48px;
    color: #fff;
  }

  .blog-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-date {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .blog-card h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-dark);
    line-height: 1.4;
    margin-bottom: 12px;
  }

  .blog-card p {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    flex-grow: 1;
    margin-bottom: 16px;
  }

  .read-more {
    color: var(--color-accent);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .read-more:hover {
    opacity: 0.8;
  }

  .newsletter-section {
    margin: 100px 0;
    background: linear-gradient(135deg, #f0f4f8 0%, #e8f0f8 100%);
    border-radius: 20px;
    padding: 60px 40px;
  }

  .newsletter-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 32px;
  }

  .newsletter-content {
    max-width: 600px;
  }

  .newsletter-content p {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .newsletter-form {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .newsletter-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
  }

  .newsletter-form input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-form button {
    padding: 12px 28px;
    background: var(--color-accent);
    color: var(--color-dark);
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s;
  }

  .newsletter-form button:hover {
    background: #52d696;
  }

  .newsletter-note {
    font-size: 12px;
    color: var(--color-text-muted) !important;
    margin: 0 !important;
  }

  .coming-soon-section {
    margin: 100px 0 0;
    background: #0F2B46;
    border-radius: 20px;
    padding: 60px 40px;
    color: #fff;
  }

  .coming-soon-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 32px;
  }

  .coming-soon-content {
    max-width: 700px;
  }

  .coming-soon-content p {
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .planned-topics h3 {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
  }

  .planned-topics ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .planned-topics li {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    margin-bottom: 12px;
    padding-left: 24px;
    position: relative;
  }

  .planned-topics li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .newsletter-section,
    .coming-soon-section {
      padding: 40px 20px;
    }

    .newsletter-section h2,
    .coming-soon-section h2 {
      font-size: 28px;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
