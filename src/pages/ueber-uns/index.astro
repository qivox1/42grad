---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import CTA from '../../components/CTA.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const brandValues = [
  {
    num: '01',
    title: 'Souveränität',
    text: 'Ihre Daten verlassen nie Ihr Haus. Wir liefern eine Plattform, die Ihnen gehört – keine Dienstleistung, die Sie abhängig macht. On-Premises ist keine technische Option, sondern unser Grundprinzip.',
    image: 'wert-souveraenitaet.webp',
    imageAlt: 'Digitale Souveränität – sichere On-Premises-Infrastruktur für den Mittelstand',
    color: 'val--azure',
  },
  {
    num: '02',
    title: 'Qualität',
    text: 'Made in Ostwestfalen. Mit dem Anspruch des deutschen Ingenieurwesens: Keine Beta-Features im Produktivbetrieb, keine Kompromisse bei Sicherheit. Wir bauen Software, die jahrelang trägt.',
    image: 'wert-qualitaet.webp',
    imageAlt: 'Deutsche Qualität in der Softwareentwicklung – präzise, verlässlich, zukunftssicher',
    color: 'val--mint',
  },
  {
    num: '03',
    title: 'Partnerschaft',
    text: 'Wir sind kein Ticketsystem. Wir sind Ihr technologischer Partner – auf Augenhöhe, langfristig, erreichbar. Wenn Ihr Prozess nicht funktioniert, ist das unser Problem.',
    image: 'wert-partnerschaft.webp',
    imageAlt: 'Partnerschaft auf Augenhöhe – 42 Grad als langfristiger technologischer Begleiter',
    color: 'val--light',
  },
  {
    num: '04',
    title: 'Nachhaltigkeit',
    text: 'On-Premises bedeutet weniger Energie als Hyperscaler-Rechenzentren. Technologie, die ökonomisch und ökologisch Sinn ergibt – für heute und für die nächste Generation.',
    image: 'wert-nachhaltigkeit.webp',
    imageAlt: 'Nachhaltige KI-Technologie – energieeffizient und zukunftsorientiert',
    color: 'val--dark',
  },
  {
    num: '05',
    title: 'Innovation',
    text: 'Vorreiter der europäischen KI-Souveränität. Wir setzen keine Trends – wir antizipieren, was mittelständische Unternehmen in drei Jahren brauchen. Und wir bauen es heute.',
    image: 'wert-innovation.webp',
    imageAlt: 'Innovation mit Verantwortung – europäische KI-Souveränität Made in Germany',
    color: 'val--azure',
  },
];
---

<Layout title="Über 42grad GmbH – KI-Technologie Made in Ostwestfalen"
  description="42grad GmbH aus Ostwestfalen-Lippe: Entwickler von 42°OS, dem KI-Betriebssystem für den Mittelstand. Unsere Mission, Werte und Technologie.">
  <Header />
  <main class="page">
    <PageHero
      breadcrumbs={[{label:'Über uns'}]}
        title="<span class='highlight'>Über</span> 42 Grad"
        subtitle="Das KI-Betriebssystem für den Mittelstand – Made in Ostwestfalen"
      image="kv-ueber-uns.webp"
    />
    <div class="container">

      <section class="brand-story">
        <div class="story-content">
          <h2>Unsere Geschichte</h2>
          <p>
            42 Grad wurde gegründet mit einer klaren Vision: den deutschen Mittelstand mit einer KI-Plattform zu befähigen, die Datenhoheit, Sicherheit und Innovation vereint. Wir verstanden ein großes Unbehagen: Viele mittelständische Unternehmen zögern, KI zu nutzen, weil sie nicht bereit sind, ihre Daten an große Cloud-Provider zu übergeben oder sich in proprietäre Systeme zu sperren.
          </p>
          <p>
            Das war der Ausgangspunkt. Wir fragten: Warum gibt es keine KI-Plattform, die vollständig On-Premises läuft, DSGVO-konform ist und echte Geschäftsprozesse automatisiert? Die Antwort: Es gab sie nicht. Also haben wir sie gebaut.
          </p>
          <p>
            42°OS ist nicht einfach ein weiteres SaaS-Tool. Es ist eine vollständig dezentrale Plattform, die auf Ihren Systemen läuft. Ihre Daten gehören Ihnen – 100 %. Keine Cloud-Abhängigkeit, keine versteckten Kosten, keine überraschenden Gebührenerhöhungen. Made in Germany nach europäischen Standards, mit transparenten Businessmodellen und echtem Support für mittelständische Herausforderungen.
          </p>
          <p>
            Heute arbeiten wir mit echten Kunden zusammen – Pilotanwender und strategische Partner, die bereits sehen, wie 42°OS ihre Prozesse automatisiert, ihre Teams entlastet und ihre Wettbewerbsfähigkeit stärkt. Und wir erweitern ständig, was möglich ist.
          </p>
        </div>
      </section>

      <section class="stats-section">
        <h2>Unsere Zahlen</h2>
        <div class="stats-grid">
          <div class="stat">
            <div class="stat-label">Gründung</div>
            <div class="stat-value">Q4 2024</div>
          </div>
          <div class="stat">
            <div class="stat-label">KI/ML-Experten</div>
            <div class="stat-value">6+</div>
          </div>
          <div class="stat">
            <div class="stat-label">Pilotanwender</div>
            <div class="stat-value">5</div>
          </div>
          <div class="stat">
            <div class="stat-label">Strategische Partner</div>
            <div class="stat-value">4</div>
          </div>
        </div>
      </section>

      <section class="values-section">
        <div class="values-section-header">
          <span class="section-label">Unsere Werte</span>
          <h2>Was uns antreibt –<br /><span class="highlight">und was uns unterscheidet.</span></h2>
          <p>
            Werte sind keine Marketingformeln. Das hier ist, wie wir arbeiten, was wir versprechen und woran wir uns messen lassen.
          </p>
        </div>

        <div class="brand-values-grid">
          {brandValues.map((val) => (
            <div class={`brand-value-card ${val.color}`}>
              <div class="bv-image-wrapper">
                <img
                  src={`${base}/images/${val.image}`}
                  alt={val.imageAlt}
                  class="bv-img"
                  loading="lazy"
                  width="480"
                  height="280"
                />
              </div>
              <div class="bv-content">
                <span class="bv-num">{val.num}</span>
                <h3 class="bv-title">{val.title}</h3>
                <p class="bv-text">{val.text}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="team-preview-section">
        <h2>Das Gründungsteam</h2>
        <div class="team-preview-grid">
          <div class="team-card">
            <h3>Jonas Fröhleke</h3>
            <p class="role">CEO & Co-Founder</p>
            <p class="bio">
              MBA & Engineering (Business Engineering) mit 12+ Jahren Expertise in Industrieautomatisierung. Jonas verbindet technisches Know-how mit unternehmerischer Vision und versteht die Herausforderungen des Mittelstands.
            </p>
          </div>
          <div class="team-card">
            <h3>Johann-Georg Vogelhuber</h3>
            <p class="role">CTO & Co-Founder</p>
            <p class="bio">
              Dipl.-Mathematiker mit 20+ Jahren Software-Entwicklung und KI-Systemdesign. Ehemals Head of AI bei GAMOMAT. Johann-Georg ist der Architekt hinter 42°OS und treibt Innovation voran.
            </p>
          </div>
        </div>
        <div class="team-cta">
          <p>Lerne mehr über unser Team und die Menschen, die 42 Grad prägen.</p>
          <a href={base + '/ueber-uns/team/'} class="btn-accent">Zum Team</a>
        </div>
      </section>

      <section class="mission-section">
        <h2>Unsere Mission</h2>
        <div class="mission-content">
          <p>
            Wir glauben, dass der deutsche Mittelstand das Rückgrat unserer Wirtschaft ist. Doch viele mittelständische Unternehmen können nicht mit großen Konzernen und Tech-Unternehmen konkurrieren, weil sie keinen Zugang zu modernen, souveränen KI-Technologien haben.
          </p>
          <p>
            42°OS ändert das. Wir ermöglichen es mittelständischen Unternehmen, ihre Geschäftsprozesse zu automatisieren – schnell, sicher und wirtschaftlich. Wir geben ihnen die gleichen Werkzeuge wie die Großen, nur besser: autonärer, kontrollierter, transparenter.
          </p>
          <p>
            Unsere Mission ist es, den Mittelstand mit KI-Technologien auszustatten, die ihre Datenhoheit bewahren, ihre Unabhängigkeit stärken und ihnen ermöglichen, mit Großkonzernen zu konkurrieren. Das ist mehr als Business – das ist Verantwortung.
          </p>
        </div>
      </section>
    </div>
  </main>
  <CTA />
  <Footer />
</Layout>

<style>

  .brand-story {
    margin: 80px 0;
    max-width: 900px;
  }

  .story-content h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 32px;
  }

  .story-content p {
    font-size: 16px;
    color: var(--color-text-light);
    line-height: 1.9;
    margin-bottom: 24px;
  }

  .story-content p:last-of-type {
    margin-bottom: 0;
  }

  .stats-section {
    margin: 100px 0;
    background: linear-gradient(135deg, #f0f4f8 0%, #e8f0f8 100%);
    border-radius: 20px;
    padding: 60px 40px;
  }

  .stats-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 50px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 28px;
  }

  .stat {
    background: #fff;
    border-radius: 12px;
    padding: 28px;
    text-align: center;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .stat-value {
    font-size: 42px;
    font-weight: 700;
    color: var(--color-accent);
  }

  /* Values section */
  .values-section {
    margin: 100px 0;
  }

  .values-section-header {
    max-width: 640px;
    margin-bottom: 56px;
  }

  .values-section-header h2 {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .values-section-header h2 .highlight {
    color: var(--color-accent);
  }

  .values-section-header p {
    font-size: 16px;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .brand-values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* 5th card spans full width of the last "row" on desktop, centered */
  .brand-values-grid .brand-value-card:nth-child(4) {
    grid-column: 1 / 2;
  }
  .brand-values-grid .brand-value-card:nth-child(5) {
    grid-column: 2 / 3;
  }

  .brand-value-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .brand-value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15, 43, 70, 0.1);
  }

  .bv-image-wrapper {
    aspect-ratio: 12 / 7;
    overflow: hidden;
    background: linear-gradient(135deg, #0F2B46, #1a3d58);
  }

  .bv-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .brand-value-card:hover .bv-img {
    transform: scale(1.04);
  }

  .bv-content {
    padding: 24px 28px 28px;
    flex: 1;
  }

  .val--azure .bv-content { background: var(--color-bg-azure); }
  .val--mint .bv-content  { background: var(--color-bg-mint); }
  .val--light .bv-content { background: #fff; }
  .val--dark .bv-content  { background: #0F2B46; }
  .val--dark .bv-title,
  .val--dark .bv-text     { color: #fff; }
  .val--dark .bv-num      { color: var(--color-accent-bright); }
  .val--dark .bv-text     { color: rgba(255,255,255,0.8); }

  .bv-num {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
  }

  .bv-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 10px;
  }

  .bv-text {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  .team-preview-section {
    margin: 100px 0;
  }

  .team-preview-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 50px;
  }

  .team-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
  }

  .team-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
  }

  .team-card h3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 8px;
  }

  .team-card .role {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .team-card .bio {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 0;
  }

  .team-cta {
    text-align: center;
    padding: 40px;
    background: linear-gradient(135deg, #f0f4f8 0%, #e8f0f8 100%);
    border-radius: 16px;
  }

  .team-cta p {
    font-size: 16px;
    color: var(--color-text-light);
    margin-bottom: 20px;
  }

  .team-cta .btn-accent {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background: var(--color-accent-bright);
    color: var(--color-dark);
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
  }

  .team-cta .btn-accent:hover {
    background: #52d696;
  }

  .mission-section {
    margin: 100px 0;
    background: #0F2B46;
    border-radius: 20px;
    padding: 60px 40px;
    color: #fff;
  }

  .mission-section h2 {
    font-size: 36px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 32px;
  }

  .mission-content {
    max-width: 800px;
  }

  .mission-content p {
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    line-height: 1.9;
    margin-bottom: 24px;
  }

  .mission-content p:last-of-type {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .brand-values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .brand-values-grid .brand-value-card:nth-child(4),
    .brand-values-grid .brand-value-card:nth-child(5) {
      grid-column: auto;
    }
  }

  @media (max-width: 768px) {
    .brand-story {
      margin: 60px 0;
    }

    .stats-section,
    .values-section,
    .team-preview-section,
    .mission-section {
      padding: 40px 20px;
    }

    .stats-section h2,
    .team-preview-section h2,
    .mission-section h2,
    .story-content h2 {
      font-size: 28px;
    }

    .brand-values-grid {
      grid-template-columns: 1fr;
    }

    .team-preview-grid {
      gap: 24px;
    }
  }
</style>
