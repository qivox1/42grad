---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Kontakt – 42grad GmbH | KI-Plattform für den Mittelstand"
  description="Kontaktieren Sie uns für eine unverbindliche Demo von 42°OS. Wir zeigen Ihnen, wie unsere On-Premises-KI-Plattform Ihre Geschäftsprozesse automatisiert."
>
  <Header />
  <main class="contact-page">

    <section class="contact-hero">
      <div class="container">
        <span class="section-label">Kontakt</span>
        <h1>Sprechen wir über Ihre <span class="highlight">Prozessautomatisierung</span></h1>
        <p class="hero-sub">Vereinbaren Sie eine unverbindliche Demo und erfahren Sie, wie 42°OS Ihre Geschäftsprozesse sicher, souverän und skalierbar automatisiert.</p>
      </div>
    </section>

    <section class="contact-content">
      <div class="container contact-grid">

        <div class="contact-info">
          <h2>So erreichen Sie uns</h2>

          <div class="info-block">
            <div class="info-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h3>E-Mail</h3>
              <a href="mailto:info@42-grad.com" class="info-link">info@42-grad.com</a>
            </div>
          </div>

          <div class="info-block">
            <div class="info-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div>
              <h3>Standort</h3>
              <p>Ostwestfalen-Lippe, Deutschland</p>
            </div>
          </div>

          <div class="info-block">
            <div class="info-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h3>Made in Germany</h3>
              <p>DSGVO-konform &amp; On-Premises</p>
            </div>
          </div>

          <div class="demo-box">
            <h3>Was Sie in der Demo erwartet</h3>
            <ul>
              <li>Live-Demonstration der 42°OS Plattform</li>
              <li>Individuelle Analyse Ihrer Prozesse</li>
              <li>Konkrete Automatisierungsszenarien für Ihr Unternehmen</li>
              <li>Technische Fragen zur On-Premises-Architektur</li>
              <li>Transparente Preis- und Lizenzinformationen</li>
            </ul>
          </div>
        </div>

        <div class="contact-form-wrapper">
          <h2>Demo anfragen</h2>
          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="firstname">Vorname <span class="required">*</span></label>
                <input type="text" id="firstname" name="firstname" placeholder="Max" required />
              </div>
              <div class="form-group">
                <label for="lastname">Nachname <span class="required">*</span></label>
                <input type="text" id="lastname" name="lastname" placeholder="Mustermann" required />
              </div>
            </div>
            <div class="form-group">
              <label for="email">E-Mail-Adresse <span class="required">*</span></label>
              <input type="email" id="email" name="email" placeholder="max@unternehmen.de" required />
            </div>
            <div class="form-group">
              <label for="company">Unternehmen <span class="required">*</span></label>
              <input type="text" id="company" name="company" placeholder="Mustermann GmbH" required />
            </div>
            <div class="form-group">
              <label for="employees">Unternehmensgröße</label>
              <select id="employees" name="employees">
                <option value="" disabled selected>Bitte wählen</option>
                <option value="1-50">1–50 Mitarbeiter</option>
                <option value="51-250">51–250 Mitarbeiter</option>
                <option value="251-1000">251–1.000 Mitarbeiter</option>
                <option value="1000+">Über 1.000 Mitarbeiter</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Ihre Nachricht</label>
              <textarea id="message" name="message" rows="4" placeholder="Beschreiben Sie kurz, welche Prozesse Sie automatisieren möchten oder stellen Sie Ihre Fragen ..."></textarea>
            </div>
            <div class="form-checkbox">
              <input type="checkbox" id="privacy" name="privacy" required />
              <label for="privacy">Ich habe die <a href={base + '/datenschutz'}>Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="required">*</span></label>
            </div>
            <button type="submit" class="btn-accent btn-submit">Demo anfragen</button>
            <p class="form-note">Wir melden uns in der Regel innerhalb von 24 Stunden bei Ihnen.</p>
          </form>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .contact-page { padding-bottom: 100px; }

  .contact-hero {
    padding: 80px 0 60px;
    background: linear-gradient(180deg, #f0f4f8 0%, #fff 100%);
  }

  .contact-hero h1 {
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.2;
    margin: 16px 0 20px;
  }

  .highlight { color: var(--color-accent); }

  .hero-sub {
    font-size: 18px;
    color: var(--color-text-light);
    max-width: 620px;
    line-height: 1.7;
  }

  .contact-content { padding: 80px 0 0; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 80px;
    align-items: start;
  }

  /* Info column */
  .contact-info h2, .contact-form-wrapper h2 {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 36px;
  }

  .info-block {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 32px;
  }

  .info-icon {
    width: 44px;
    height: 44px;
    background: #f0f4f8;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-dark);
  }

  .info-block h3 {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-block p { font-size: 15px; color: var(--color-text-light); margin: 0; }

  .info-link {
    font-size: 15px;
    color: var(--color-accent);
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .info-link:hover { opacity: 0.75; }

  .demo-box {
    background: var(--color-dark);
    border-radius: 16px;
    padding: 32px;
    margin-top: 16px;
    color: #fff;
  }

  .demo-box h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .demo-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .demo-box li {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    padding-left: 22px;
    position: relative;
    line-height: 1.5;
  }

  .demo-box li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .form-group { display: flex; flex-direction: column; gap: 8px; }

  .form-group label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .required { color: var(--color-accent); }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    color: var(--color-dark);
    background: #fff;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-group textarea { resize: vertical; }

  .form-checkbox {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .form-checkbox input[type="checkbox"] { margin-top: 3px; flex-shrink: 0; }

  .form-checkbox label {
    font-size: 13px;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .form-checkbox label a { color: var(--color-accent); }

  .btn-submit {
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 700;
    width: 100%;
    border: none;
    cursor: pointer;
    border-radius: 50px;
  }

  .form-note {
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
