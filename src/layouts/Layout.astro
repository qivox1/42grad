---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '42 Grad – Das KI-Betriebssystem für den deutschen Mittelstand',
  description = '42°OS – On-Premises-Plattform für autonome Geschäftsprozesse. 100% Datenhoheit, DSGVO-konform, planbare Kosten. Made in Germany.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, 'https://qivox1.github.io').href;
const ogImage = `https://qivox1.github.io${base}/images/header_01.webp`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="816" />
    <meta property="og:site_name" content="42 Grad – 42°OS" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Fonts: preload + non-render-blocking async load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" /></noscript>

    <!-- LCP preload: hero image for homepage -->
    <link rel="preload" as="image" href={`${base}/images/header_01.webp`} fetchpriority="high" />

    <title>{title}</title>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://qivox1.github.io/42grad/#organization",
          "name": "42grad GmbH",
          "url": "https://qivox1.github.io/42grad/",
          "logo": "https://qivox1.github.io/42grad/favicon.svg",
          "foundingDate": "2024",
          "founders": [
            { "@type": "Person", "name": "Jonas Fröhleke", "jobTitle": "CEO" },
            { "@type": "Person", "name": "Johann-Georg Vogelhuber", "jobTitle": "CTO" }
          ],
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Ostwestfalen-Lippe",
            "addressCountry": "DE"
          },
          "description": "Die 42grad GmbH entwickelt mit 42°OS ein KI-Betriebssystem für den deutschen Mittelstand – On-Premises, DSGVO-konform und mit 100% Datenhoheit."
        },
        {
          "@type": "WebSite",
          "@id": "https://qivox1.github.io/42grad/#website",
          "url": "https://qivox1.github.io/42grad/",
          "name": "42 Grad – Das KI-Betriebssystem für den Mittelstand",
          "description": "42°OS – On-Premises-Plattform für autonome Geschäftsprozesse. 100% Datenhoheit, DSGVO-konform, planbare Kosten.",
          "publisher": { "@id": "https://qivox1.github.io/42grad/#organization" },
          "inLanguage": "de-DE"
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://qivox1.github.io/42grad/#software",
          "name": "42°OS",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "On-Premises, Docker",
          "description": "42°OS ist eine On-Premises-Plattform für autonome Geschäftsprozesse. Sie ermöglicht volle Datenhoheit und schafft Prozesse, die sicher, souverän und beliebig skalierbar sind – mit lokalem LLM, No-Code-Designer und KI-Agenten.",
          "url": "https://qivox1.github.io/42grad/",
          "publisher": { "@id": "https://qivox1.github.io/42grad/#organization" },
          "offers": {
            "@type": "Offer",
            "priceCurrency": "EUR",
            "description": "Planbare Jahreslizenz ohne Pay-per-Use"
          },
          "featureList": [
            "Lokale LLM-Ausführung",
            "Multi-Layer Security (RBAC)",
            "Docker-basierte Architektur",
            "No-Code Workflow Designer",
            "Agentic AI mit 50+ Agenten",
            "REST API & Webhook Support",
            "DSGVO-konform"
          ]
        }
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
